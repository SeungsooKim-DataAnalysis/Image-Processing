#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <stdlib.h>
#include <windows.h>

int main()
{
    BITMAPFILEHEADER bmpFile;
    BITMAPINFOHEADER bmpInfo;
    FILE* inputFile = NULL;
    inputFile = fopen("AICenter.bmp", "rb");
    fread(&bmpFile, sizeof(BITMAPFILEHEADER), 1, inputFile);
    fread(&bmpInfo, sizeof(BITMAPINFOHEADER), 1, inputFile);

    int width = bmpInfo.biWidth;
    int height = bmpInfo.biHeight;
    int size = bmpInfo.biSizeImage;
    int bitCnt = bmpInfo.biBitCount;
    int stride = (((bitCnt / 8) * width) + 3) / 4 * 4;
    printf("w: %d(%d)\nH: %d\nS: %d\nD: %d\n\n", width, stride, height, size, bitCnt);

    unsigned char* inputImg = NULL, * outputImg = NULL;
    inputImg = (unsigned char*)calloc(size, sizeof(unsigned char));
    outputImg = (unsigned char*)calloc(size, sizeof(unsigned char));
    fread(inputImg, sizeof(unsigned char), size, inputFile);

    //2차 동적할당
    double** tmpY = (double**)malloc(height * sizeof(double*));
    double** tmpCb = (double**)malloc(height * sizeof(double*));
    double** tmpCr = (double**)malloc(height * sizeof(double*));
    for (int i = 0; i < height; i++) {
        tmpY[i] = (double*)malloc(width * sizeof(double));
        tmpCb[i] = (double*)malloc(width * sizeof(double));
        tmpCr[i] = (double*)malloc(width * sizeof(double));
    }

    for (int i = 0; i < height; i++) {
        for (int j = 0; j < width; j++) {
            tmpY[i][j] =
                0.299 * inputImg[i * stride + 3 * j + 2] +
                0.587 * inputImg[i * stride + 3 * j + 1] +
                0.114 * inputImg[i * stride + 3 * j + 0];
            tmpCb[i][j] =
                -0.169 * inputImg[i * stride + 3 * j + 2] -
                0.331 * inputImg[i * stride + 3 * j + 1] +
                0.500 * inputImg[i * stride + 3 * j + 0];
            tmpCr[i][j] =
                0.500 * inputImg[i * stride + 3 * j + 2] -
                0.419 * inputImg[i * stride + 3 * j + 1] -
                0.0813 * inputImg[i * stride + 3 * j + 0];
        }
    }

    for (int i = 0; i < height; i++) {//형변환
        for (int j = 0; j < width; j++) {
            inputImg[i * stride + 3 * j + 0] = (unsigned char)(tmpY[i][j] > 255 ? 255 : (tmpY[i][j] < 0 ? 0 : tmpY[i][j]));;
            inputImg[i * stride + 3 * j + 1] = (unsigned char)(tmpY[i][j] > 255 ? 255 : (tmpY[i][j] < 0 ? 0 : tmpY[i][j]));;
            inputImg[i * stride + 3 * j + 2] = (unsigned char)(tmpY[i][j] > 255 ? 255 : (tmpY[i][j] < 0 ? 0 : tmpY[i][j]));;
        }
    }

    //역변환 변수 동적할당
    double** R = (double**)malloc(sizeof(double*) * height);
    double** G = (double**)malloc(sizeof(double*) * height);
    double** B = (double**)malloc(sizeof(double*) * height);

    for (int i = 0; i < height; i++) {
        R[i] = (double*)malloc(sizeof(double) * width);
        G[i] = (double*)malloc(sizeof(double) * width);
        B[i] = (double*)malloc(sizeof(double) * width);
    }

    for (int i = 0; i < height; i++) {//역변환
        for (int j = 0; j < width; j++) {
            R[i][j] = tmpY[i][j] + 1.402 * tmpCr[i][j];
            G[i][j] = tmpY[i][j] - 0.714 * tmpCr[i][j] - 0.344 * tmpCb[i][j];
            B[i][j] = tmpY[i][j] + 1.772 * tmpCb[i][j];
        }
    }
    for (int i = 0; i < height; i++) {//형변환
        for (int j = 0; j < width; j++) {
            inputImg[i * stride + 3 * j + 0] = (unsigned char)(B[i][j] > 255 ? 255 : (B[i][j] < 0 ? 0 : B[i][j]));;
            inputImg[i * stride + 3 * j + 1] = (unsigned char)(G[i][j] > 255 ? 255 : (G[i][j] < 0 ? 0 : G[i][j]));;
            inputImg[i * stride + 3 * j + 2] = (unsigned char)(R[i][j] > 255 ? 255 : (R[i][j] < 0 ? 0 : R[i][j]));;
        }
    }    

    //output <- input
    for (int i = 0; i < height; i++) {
        for (int j = 0; j < width; j++) {
            outputImg[i * stride + 3 * j + 0] = inputImg[i * stride + 3 * j + 0];
            outputImg[i * stride + 3 * j + 1] = inputImg[i * stride + 3 * j + 1];
            outputImg[i * stride + 3 * j + 2] = inputImg[i * stride + 3 * j + 2];
        }
    }

    FILE* outputFile = fopen("Output.bmp", "wb");
    fwrite(&bmpFile, sizeof(BITMAPFILEHEADER), 1, outputFile);
    fwrite(&bmpInfo, sizeof(BITMAPINFOHEADER), 1, outputFile);
    fwrite(outputImg, sizeof(unsigned char), size, outputFile);


    for (int i = 0; i < height; i++) {
        free(tmpY[i]);
    }
    free(tmpY);

    free(inputImg);
    free(outputImg);
    fclose(inputFile);
    fclose(outputFile);

    return 0;
}

#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <math.h>
#include <stdlib.h>
#include <windows.h>

int main()
{
    BITMAPFILEHEADER bmpFile1, bmpFile2;
    BITMAPINFOHEADER bmpInfo1, bmpInfo2;
    FILE* inputFile1 = NULL, * inputFile2 = NULL;
    inputFile1 = fopen("AICenterY.bmp", "rb");
    fread(&bmpFile1, sizeof(BITMAPFILEHEADER), 1, inputFile1);
    fread(&bmpInfo1, sizeof(BITMAPINFOHEADER), 1, inputFile1);
    inputFile2 = fopen("AICenterY_Noise.bmp", "rb");
    fread(&bmpFile2, sizeof(BITMAPFILEHEADER), 1, inputFile2);
    fread(&bmpInfo2, sizeof(BITMAPINFOHEADER), 1, inputFile2);

    int size = bmpInfo1.biSizeImage;
    int width = bmpInfo1.biWidth;
    int height = bmpInfo1.biHeight;
    int bitCnt = bmpInfo1.biBitCount;
    int stride = (((bitCnt / 8) * width) + 3) / 4 * 4;
    
    unsigned char* inputImg1 = NULL, * inputImg2 = NULL;
    inputImg1 = (unsigned char*)calloc(size, sizeof(unsigned char));
    inputImg2 = (unsigned char*)calloc(size, sizeof(unsigned char));    
    fread(inputImg1, sizeof(unsigned char), size, inputFile1);
    fread(inputImg2, sizeof(unsigned char), size, inputFile2);
    
    /*1차열 배열
    double* Y1 = (double*)malloc(sizeof(double) * width * height);
    double* Y2 = (double*)malloc(sizeof(double) * width * height);
    for (int i = 0; i < height; i++) {
        for (int j = 0; j < width; j++) {
            Y1[i * width + j] = inputImg1[i * stride + 3 * j + 0];
            Y2[i * width + j] = inputImg2[i * stride + 3 * j + 0];
        }
    }
    double mse = 0, psnr;
    for (int i = 0; i < height; i++) {
        for (int j = 0; j < width; j++) {
            mse += (Y2[i * width + j] - Y1[i * width + j]) * (Y2[i * width + j] - Y1[i * width + j]);
        }
    }*/

    //2차원 배열
    double** Y = (double**)malloc(sizeof(double*) * height);
    double** Y1 = (double**)malloc(sizeof(double*) * height);
    double** Y2 = (double**)malloc(sizeof(double*) * height);
    for (int i = 0; i < height; i++) {
        Y[i] = (double*)malloc(sizeof(double) * width);
        Y1[i] = (double*)malloc(sizeof(double) * width);
        Y2[i] = (double*)malloc(sizeof(double) * width);        
    }

    //InputImg1 = Color, InputImg2 = Luminance
    for (int i = 0; i < height; i++) {
        for (int j = 0; j < width; j++) {
            Y[i][j] = 0.299 * inputImg1[i * stride + 3 * j + 2] + 0.587 * inputImg1[i * stride + 3 * j + 1] + 0.114 * inputImg1[i * stride + 3 * j + 0];
            Y1[i][j] = (unsigned char)(Y[i][j] > 255 ? 255 : (Y[i][j] < 0 ? 0 : Y[i][j]));
            Y2[i][j] = inputImg2[i * stride + 3 * j + 0];
        }
    }

    //InputImg1 = Luminance, InputImg2 = Luminance
   for (int i = 0; i < height; i++) {
        for (int j = 0; j < width; j++) {
            Y1[i][j] = inputImg2[i * stride + 3 * j + 0];
            Y2[i][j] = inputImg1[i * stride + 3 * j + 0];
        }
    }
    
    double mse = 0, psnr;
    for (int i = 0; i < height; i++) {
        for (int j = 0; j < width; j++) {
            mse += (double)(Y2[i][j] - Y1[i][j]) * (Y2[i][j] - Y1[i][j]);
        }
    }
    mse /= (width * height);
    psnr = mse != 0.0 ? 10.0 * log10(255 * 255 / mse) : 99.99;
    printf("MSE = %.2lf\nPSNR = %.2lf dB\n", mse, psnr);
    
    free(inputImg1);
    free(inputImg2);
    fclose(inputFile1);
    fclose(inputFile2);  

    return 0;
}
